        {
          "name": "TC-API-001 Get All Products",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Products list exists\", function () {\r",
                  "\r",
                  "    const jsonData = pm.response.json();\r",
                  "\r",
                  "    pm.expect(jsonData.products).to.exist;\r",
                  "\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Products array is not empty\", function () {\r",
                  "\r",
                  "    const jsonData = pm.response.json();\r",
                  "\r",
                  "    pm.expect(jsonData.products.length).to.be.above(0);\r",
                  "\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "https://automationexercise.com/api/productsList",
              "protocol": "https",
              "host": [
                "automationexercise",
                "com"
              ],
              "path": [
                "api",
                "productsList"
              ]
            }
          },
          "response": []
        },
